# Appwrite (Cloud ou self-hosted)
VITE_APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69ab68b70029335e9551

# URL pública do app usada nos links de verificação, recuperação e login social
